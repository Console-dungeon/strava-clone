{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(php artisan *)",
      "Bash(pnpm run *)",
      "Bash(sudo DEBIAN_FRONTEND=noninteractive apt-get install -y texlive-latex-base texlive-latex-recommended texlive-latex-extra texlive-lang-polish texlive-fonts-recommended lmodern)",
      "Bash(find /usr /opt /home -name \"pdflatex\" 2>/dev/null | head -5 *)",
      "Read(//usr/**)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/format.sh",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
