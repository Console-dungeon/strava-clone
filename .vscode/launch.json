{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Full Stack (Laravel + Vite)",
      "runtimeExecutable": "composer",
      "runtimeArgs": ["dev"],
      "cwd": "${workspaceFolder}",
      "console": "internalConsole",
      "type": "node",
      "request": "launch",
      "serverReadyAction": {
        "pattern": "Local:",
        "uriFormat": "http://localhost",
        "action": "openExternally"
      }
    }
  ]
}
